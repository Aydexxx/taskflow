# ---------------------------------------------------------------------------
# TaskFlow server environment
# Copy this file to ".env" and adjust values for your environment.
# ---------------------------------------------------------------------------

# Database connection string used by Prisma.
#
# Local development (SQLite, default): a file relative to the prisma/ folder.
DATABASE_URL="file:./dev.db"
#
# Production (PostgreSQL): switch the `datasource` provider in
# prisma/schema.prisma to "postgresql" and use a URL like:
# DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"

# Secret used to sign/verify JWTs. Use a long, random value in production.
JWT_SECRET="change-me-in-production"

# How long an access token stays valid (jsonwebtoken "expiresIn" format).
JWT_EXPIRES_IN="7d"

# Origin of the frontend, used for CORS and Socket.IO allowed origins.
CLIENT_URL="http://localhost:5173"

# Port the HTTP + Socket.IO server listens on.
PORT="4000"

# ---------------------------------------------------------------------------
# AI assist (optional). TaskFlow runs fully with NO AI configured.
#
# Provider is config-only. Leave AI_PROVIDER unset or "none" to keep every AI
# feature inert: AI endpoints respond 404 and no AI UI is shown. Set it to
# "openai" or "ollama" (and supply the matching values) to light AI up — no
# code changes required.
# ---------------------------------------------------------------------------

# One of: none | openai | ollama  (default: none)
AI_PROVIDER="none"

# --- OpenAI (AI_PROVIDER=openai) ---
# Required for OpenAI; without it AI stays disabled even if AI_PROVIDER=openai.
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBED_MODEL="text-embedding-3-small"
# Override to target an OpenAI-compatible gateway.
OPENAI_BASE_URL="https://api.openai.com/v1"

# --- Ollama (AI_PROVIDER=ollama) ---
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"
OLLAMA_EMBED_MODEL="nomic-embed-text"

# --- Shared AI guards ---
# Max AI requests per user per rolling minute.
AI_RATE_LIMIT_PER_MINUTE="10"
# Per-request timeout (ms) for outbound LLM calls.
AI_REQUEST_TIMEOUT_MS="30000"
