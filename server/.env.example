# ---------------------------------------------------------------------------
# TaskFlow server environment
# Copy this file to ".env" and adjust values for your environment.
# ---------------------------------------------------------------------------

# Database connection string used by Prisma.
#
# Local development (SQLite, default): a file relative to the prisma/ folder.
DATABASE_URL="file:./dev.db"
#
# Production (PostgreSQL): switch the `datasource` provider in
# prisma/schema.prisma to "postgresql" and use a URL like:
# DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"

# Secret used to sign/verify JWTs. Use a long, random value in production.
JWT_SECRET="change-me-in-production"

# How long an access token stays valid (jsonwebtoken "expiresIn" format).
JWT_EXPIRES_IN="7d"

# Origin of the frontend, used for CORS and Socket.IO allowed origins.
CLIENT_URL="http://localhost:5173"

# Port the HTTP + Socket.IO server listens on.
PORT="4000"
